{
  "name": "md-zh-translation-skill",
  "version": "1.5.0",
  "description": "CLI skill for translating English Markdown articles into polished Chinese Markdown with a hidden gated pipeline.",
  "type": "module",
  "bin": {
    "md-zh-translate": "./dist/src/cli.js",
    "md-zh-translate-mcp": "./dist/src/mcp-server.js"
  },
  "files": [
    "dist/src",
    "README.md",
    "SKILL.md",
    "agents"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build:smoke-fixtures": "node scripts/build-smoke-fixtures.mjs",
    "smoke:short": "node scripts/run-smoke.mjs --fixture short",
    "smoke:full": "node scripts/run-smoke.mjs --fixture full",
    "smoke:status": "node scripts/smoke-status.mjs",
    "smoke:diagnose": "node scripts/smoke-diagnose.mjs",
    "smoke:quality": "node scripts/smoke-quality.mjs",
    "smoke:once": "node scripts/smoke-once.mjs",
    "build": "tsc -p tsconfig.json && node scripts/copy-runtime-data.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test test/**/*.test.ts",
    "verify": "npm run typecheck && npm run test && npm run build",
    "release": "semantic-release"
  },
  "exports": {
    ".": "./dist/src/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@jacobbubu/md-zh-format": "^1.0.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.6",
    "@semantic-release/npm": "^13.1.1",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/node": "^24.3.0",
    "semantic-release": "^24.2.7",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}

{
  "name": "md-zh-translation-skill",
  "version": "0.1.0",
  "description": "CLI skill for translating English Markdown articles into polished Chinese Markdown with a hidden gated pipeline.",
  "type": "module",
  "bin": {
    "md-zh-translate": "./dist/src/cli.js"
  },
  "files": [
    "dist",
    "SKILL.md",
    "agents"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test test/**/*.test.ts",
    "verify": "npm run typecheck && npm run test && npm run build",
    "release": "semantic-release"
  },
  "exports": {
    ".": "./dist/src/index.js"
  },
  "dependencies": {
    "@jacobbubu/md-zh-format": "^1.0.1"
  },
  "devDependencies": {
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.6",
    "@semantic-release/npm": "^13.1.1",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/node": "^24.3.0",
    "semantic-release": "^24.2.7",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
